# ─────────────────────────────────────────────────────────────
#  EduAI — School Server Environment Variables
#  Copy this file to .env and fill in every value before running
#  docker compose up -d for the first time.
# ─────────────────────────────────────────────────────────────

# ── Site / network ────────────────────────────────────────────
# Public URL of this school server (used for CORS and GoTrue redirects).
# For LAN-only deployments use the server's local IP, e.g. http://192.168.1.10
SITE_URL=http://localhost

# GoTrue uses this as the canonical external API URL
API_EXTERNAL_URL=http://localhost:8000

# ── Postgres ──────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password_here

# ── Supabase JWT (keep secret — minimum 32 chars) ─────────────
JWT_SECRET=change_me_jwt_secret_minimum_32_characters_here

# ── Supabase API keys (generated from JWT_SECRET + role claims)
# Use the Supabase self-hosted keygen tool or compute manually:
#   https://supabase.com/docs/guides/self-hosting#api-keys
SUPABASE_ANON_KEY=replace_with_anon_key
SUPABASE_SERVICE_KEY=replace_with_service_role_key

# ── Node API ──────────────────────────────────────────────────
# Supabase URL that the Node API connects to (internal Docker network)
# SUPABASE_URL=http://kong:8000   ← set automatically in docker-compose.yml

# ── Cloud AI provider (chat / grading / vision) ───────────────
# Any OpenAI-compatible endpoint works. When CLOUD_AI_API_KEY is set, all
# chat-completion calls go here; when unset, they run on local Ollama.
# Later, pointing CLOUD_AI_BASE_URL at your own vLLM server (same protocol)
# moves everything to the local LLM with zero code changes.
#
#   OpenRouter (one key, any model):  https://openrouter.ai/api/v1
#   Google Gemini (OpenAI compat):    https://generativelanguage.googleapis.com/v1beta/openai
#   DeepSeek:                         https://api.deepseek.com/v1
#   Groq:                             https://api.groq.com/openai/v1
#   Your own vLLM server (later):     http://<big-server-ip>:8000/v1
CLOUD_AI_BASE_URL=
CLOUD_AI_API_KEY=

# Per-task model tiers. Grading/question-gen deserve a stronger model than
# high-volume tutor chat; vision needs a multimodal model. Unset tiers fall
# back to AI_CHAT_MODEL (grading also feeds qgen's default).
# Example (OpenRouter):
#   AI_CHAT_MODEL=google/gemini-2.5-flash
#   AI_GRADING_MODEL=qwen/qwen3-32b
#   AI_VISION_MODEL=qwen/qwen2.5-vl-7b-instruct
AI_CHAT_MODEL=
AI_GRADING_MODEL=
AI_QGEN_MODEL=
AI_VISION_MODEL=

# ── Transactional email (credential mails) ───────────────────
# Unset SMTP_HOST disables sending — credentials are always shown once
# in the admin UI regardless, so email is an enhancement, not required.
# Local dev: Supabase Mailpit accepts SMTP on 54325 (web UI at :54324).
# Production: any SMTP provider (SES, Brevo, SendGrid, school's own).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=EduAI <no-reply@yourschool.example>
# Public URL of the frontend, used for links inside emails
APP_URL=

# ── Ollama (embeddings always; chat fallback when no cloud key) ──
# Embeddings run on local Ollama regardless of the cloud settings above —
# mxbai-embed-large is CPU-only, free, and the stored RAG vectors are tied
# to it (changing it means re-embedding the whole library).
# OLLAMA_URL is set to http://ollama:11434 automatically in docker-compose.yml.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=mxbai-embed-large
