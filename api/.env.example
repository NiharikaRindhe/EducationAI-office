# ─── Supabase (self-hosted, local dev via `supabase start`) ───────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-anon-key-from-supabase-status
SUPABASE_SERVICE_KEY=replace-with-service-role-key-from-supabase-status

# ─── Ollama Cloud API (LLM + vision) ───────────────────────────────
OLLAMA_CLOUD_URL=https://ollama.com/api
OLLAMA_CLOUD_API_KEY=replace-with-ollama-cloud-key
OLLAMA_CHAT_MODEL=qwen3:latest

# ─── Local Ollama (embeddings only, CPU) ───────────────────────────
OLLAMA_LOCAL_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── App ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
