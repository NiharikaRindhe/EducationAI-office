# ─── Supabase (self-hosted, local dev via `supabase start`) ───────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-anon-key-from-supabase-status
SUPABASE_SERVICE_KEY=replace-with-service-role-key-from-supabase-status
SUPABASE_JWT_SECRET=replace-with-jwt-secret-from-supabase-status

# ─── Ollama (single local daemon — model name picks local vs cloud) ─
# Cloud models need the daemon itself signed in (`ollama signin`) or its
# OLLAMA_API_KEY env var set — nothing is passed per-request from this app.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=gpt-oss:20b-cloud
OLLAMA_EMBED_MODEL=mxbai-embed-large

# ─── App ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
